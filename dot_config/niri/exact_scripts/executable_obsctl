#!/usr/bin/env bash

set -euo pipefail

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
plugin_obsctl="$config_home/noctalia/plugins/obs-control/scripts/obsctl"
obs_icon="/usr/share/icons/hicolor/scalable/apps/com.obsproject.Studio.svg"

if [[ ! -x "$plugin_obsctl" ]]; then
  echo "obsctl: plugin helper not found at $plugin_obsctl" >&2
  exit 1
fi

notify() {
  local title="$1"
  local body="${2:-}"
  local timeout="${3:-2500}"

  gdbus call \
    --session \
    --dest org.freedesktop.Notifications \
    --object-path /org/freedesktop/Notifications \
    --method org.freedesktop.Notifications.Notify \
    "OBS" \
    0 \
    "$obs_icon" \
    "$title" \
    "$body" \
    "[]" \
    "{}" \
    "$timeout" >/dev/null 2>&1 || true
}

command_name="${1:-}"

if [[ "$command_name" == "status" ]]; then
  exec "$plugin_obsctl" "$@"
fi

stdout_file="$(mktemp)"
stderr_file="$(mktemp)"

cleanup() {
  rm -f "$stdout_file" "$stderr_file"
}
trap cleanup EXIT

if "$plugin_obsctl" "$@" >"$stdout_file" 2>"$stderr_file"; then
  output="$(cat "$stdout_file")"
  if [[ -n "$output" ]] && jq -e . >/dev/null 2>&1 <<<"$output"; then
    title="$(jq -r '.title // empty' <<<"$output")"
    body="$(jq -r '.body // empty' <<<"$output")"
    if [[ -n "$title" ]]; then
      notify "$title" "$body"
    fi
  fi
  exit 0
fi

error_text="$(tr '\n' ' ' <"$stderr_file" | sed 's/[[:space:]]\\+/ /g; s/^ //; s/ $//')"
notify "OBS control failed" "${error_text:-Check the OBS helper output.}" 3500
cat "$stderr_file" >&2
exit 1
