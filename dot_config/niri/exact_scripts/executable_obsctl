#!/usr/bin/env bash

set -euo pipefail

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
script_js="$config_home/niri/scripts/obsctl.js"

resolve_node_bin() {
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi

  if command -v mise >/dev/null 2>&1; then
    mise which node 2>/dev/null && return 0
  fi

  if [[ -x "$HOME/.local/share/mise/shims/node" ]]; then
    printf '%s\n' "$HOME/.local/share/mise/shims/node"
    return 0
  fi

  return 1
}

node_bin="$(resolve_node_bin || true)"

if [[ -z "$node_bin" ]]; then
  echo "obsctl: node runtime not found in PATH or via mise" >&2
  exit 1
fi

exec "$node_bin" "$script_js" "$@"
