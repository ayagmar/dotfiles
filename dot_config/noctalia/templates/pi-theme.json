{
  "$schema": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
  "name": "noctalia",
  "vars": {
    "surface": "{{colors.surface_container.default.hex}}",
    "surfaceAlt": "{{colors.surface_container_low.default.hex}}",
    "surfaceRaised": "{{colors.surface_container_high.default.hex}}",
    "outline": "{{colors.outline.default.hex}}",
    "muted": "{{colors.on_surface_variant.default.hex}}",
    "dim": "{{colors.on_surface_variant.default.hex}}",
    "primary": "{{colors.primary.default.hex}}",
    "secondary": "{{colors.secondary.default.hex}}",
    "tertiary": "{{colors.tertiary.default.hex}}",
    "success": "{{colors.secondary.default.hex}}",
    "error": "{{colors.error.default.hex}}"
  },
  "colors": {
    "accent": "primary",
    "border": "outline",
    "borderAccent": "primary",
    "borderMuted": "outline",
    "success": "success",
    "error": "error",
    "warning": "primary",
    "muted": "muted",
    "dim": "dim",
    "text": "",
    "thinkingText": "muted",

    "selectedBg": "surfaceRaised",
    "userMessageBg": "surfaceRaised",
    "userMessageText": "",
    "customMessageBg": "surfaceAlt",
    "customMessageText": "",
    "customMessageLabel": "secondary",
    "toolPendingBg": "surfaceAlt",
    "toolSuccessBg": "surfaceAlt",
    "toolErrorBg": "surfaceAlt",
    "toolTitle": "",
    "toolOutput": "muted",

    "mdHeading": "primary",
    "mdLink": "tertiary",
    "mdLinkUrl": "dim",
    "mdCode": "tertiary",
    "mdCodeBlock": "",
    "mdCodeBlockBorder": "muted",
    "mdQuote": "muted",
    "mdQuoteBorder": "muted",
    "mdHr": "muted",
    "mdListBullet": "secondary",

    "toolDiffAdded": "success",
    "toolDiffRemoved": "error",
    "toolDiffContext": "muted",

    "syntaxComment": "muted",
    "syntaxKeyword": "primary",
    "syntaxFunction": "secondary",
    "syntaxVariable": "",
    "syntaxString": "tertiary",
    "syntaxNumber": "primary",
    "syntaxType": "secondary",
    "syntaxOperator": "",
    "syntaxPunctuation": "",

    "thinkingOff": "outline",
    "thinkingMinimal": "outline",
    "thinkingLow": "secondary",
    "thinkingMedium": "primary",
    "thinkingHigh": "tertiary",
    "thinkingXhigh": "error",

    "bashMode": "primary"
  },
  "export": {
    "pageBg": "{{colors.surface.default.hex}}",
    "cardBg": "{{colors.surface_container.default.hex}}",
    "infoBg": "{{colors.surface_container_high.default.hex}}"
  }
}
