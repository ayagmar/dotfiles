{
  "lastChangelogVersion": "0.63.1",
  "packages": [
    "npm:pi-codex-web-search",
    "npm:pi-promptsmith",
    "npm:pi-extmgr",
    {
      "source": "npm:pi-multi-pass",
      "extensions": [
        "+extensions/multi-sub.ts"
      ]
    },
    "https://github.com/davebcn87/pi-autoresearch",
    "git:github.com/edxeth/pi-gpt-config",
    "npm:pi-bash-live-view",
    {
      "source": "npm:pi-anycopy",
      "extensions": [
        "-extensions/anycopy/index.ts"
      ]
    }
  ],
  "defaultProvider": "openai-codex-6",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "xhigh",
  "hideThinkingBlock": false,
  "theme": "noctalia",
  "gptConfig": {
    "fastMode": false,
    "personality": "none",
    "verbosity": "low",
    "summary": "auto",
    "showFooter": false
  }
}